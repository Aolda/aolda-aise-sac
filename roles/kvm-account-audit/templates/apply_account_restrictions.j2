#!/bin/bash
#
# KVM 계정 자동 제한 적용 스크립트
# 용도: 검토 후 지정한 계정을 수동으로 잠금 처리
# 생성일: {{ ansible_date_time.iso8601 }}
# 호스트: {{ inventory_hostname }}
#

set -euo pipefail

# 컬러 정의
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 스크립트 파일 자체 경로
SCRIPT_PATH="$0"

# 로그 함수
log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# 도움말 함수
show_help() {
    cat << 'EOF'
KVM 계정 자동 제한 적용 스크립트

사용법:
    bash apply_account_restrictions.sh <username>

예시:
    bash apply_account_restrictions.sh kvmuser01
    bash apply_account_restrictions.sh kvmuser02

설명:
    - 지정된 사용자 계정을 잠금 처리합니다 (usermod -L)
    - 이미 잠금된 계정은 건너뜁니다 (멱등성 보장)
    - 스크립트 실행 후 자동으로 삭제됩니다
EOF
}

# 권한 확인
check_permissions() {
    if [ "$EUID" -ne 0 ]; then
        log_error "본 스크립트는 root 권한이 필요합니다."
        exit 1
    fi
}

# 계정 존재 여부 확인
check_user_exists() {
    local username=$1
    if ! id "$username" &>/dev/null; then
        log_error "계정 '$username'이 존재하지 않습니다."
        return 1
    fi
    return 0
}

# 계정 잠금 상태 확인
check_account_locked() {
    local username=$1
    local account_status=$(passwd -S "$username" 2>/dev/null | awk '{print $2}' || echo "unknown")
    
    if [ "$account_status" = "L" ]; then
        return 0  # 잠금됨 (true)
    else
        return 1  # 잠금 안됨 (false)
    fi
}

# 계정 잠금 처리
lock_account() {
    local username=$1
    
    log_info "계정 '$username' 잠금 처리 중..."
    
    if check_account_locked "$username"; then
        log_warn "계정 '$username'은(는) 이미 잠금 상태입니다."
        return 0
    fi
    
    if usermod -L "$username"; then
        log_info "계정 '$username' 잠금 완료"
        printf '%s %s locked_by_manual_script\n' "$(date -Is)" "$username" >> {{ kvm_account_action_log_path | quote }} 2>/dev/null || true
        return 0
    else
        log_error "계정 '$username' 잠금 실패"
        return 1
    fi
}

# 스크립트 자체 삭제
cleanup_self() {
    log_info "스크립트 자체 삭제 중..."
    
    if [ -f "$SCRIPT_PATH" ]; then
        rm -f "$SCRIPT_PATH"
        log_info "스크립트 삭제 완료: $SCRIPT_PATH"
    fi
}

# 메인 로직
main() {
    log_info "=========================================="
    log_info "KVM 계정 자동 제한 적용 스크립트"
    log_info "=========================================="
    
    # 인자 확인
    if [ $# -eq 0 ]; then
        log_error "사용자 계정이 지정되지 않았습니다."
        echo ""
        show_help
        exit 1
    fi
    
    if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
        show_help
        exit 0
    fi
    
    # 권한 확인
    check_permissions
    
    local username=$1
    
    # 계정 존재 여부 확인
    if ! check_user_exists "$username"; then
        exit 1
    fi
    
    # 계정 잠금 처리
    lock_account "$username"
    local lock_result=$?
    
    # 스크립트 자체 삭제
    cleanup_self
    
    if [ $lock_result -eq 0 ]; then
        log_info "=========================================="
        log_info "작업 완료"
        log_info "=========================================="
        exit 0
    else
        log_error "작업 실패"
        exit 1
    fi
}

# 스크립트 실행
main "$@"
